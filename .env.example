# AnslagSITK — kopiera till .env och fyll i värden
# Vercel: lägg samma variabler under Project → Settings → Environment Variables

# --- OpenRouter (sätt EN av dessa — samma som Vercel) ---
OPENROUTER_API_KEY=sk-or-v1-...

# free = bara gratismodeller | paid = bara betalt | auto = gratis först, sedan betalt (default)
OPENROUTER_MODEL_TIER=auto

# Valfritt: fler nycklar för failover mellan konton
OPENROUTER_KEY_PELLEGROSSO=sk-or-v1-...
OPENROUTER_KEY_CYMWAVE=sk-or-v1-...
OPENROUTER_KEY_CARL=sk-or-v1-...
OPENROUTER_KEY_HLIVFA=sk-or-v1-...
OPENROUTER_KEY_PERBRINELL=sk-or-v1-...
OPENROUTER_KEY_LEADAGENTICOS=sk-or-v1-...
OPENROUTER_KEY_PERBRINELL_MAP=sk-or-v1-...

# --- Webbsökning (rekommenderat för discover-grants) ---
EXA_API_KEY=

# --- Officiella register (bred sökning) ---
# GDP (gdphub.se): Subscribe per myndighet — använd primärnyckeln här
GDP_API_KEY_VINNOVA=
GDP_API_KEY_FORMAS=
GDP_API_KEY_FORTE=
GDP_API_KEY_VR=          # Vetenskapsrådet (inte "vetenskapsradet" i namnet)
# Sekundärnyckel från portalen = backup; byt bara om primären slutar fungera

# Swecris: ansök token på https://www.vr.se/swecris/swecris-api/
SWECRIS_API_KEY=

# Stiftelser: kör npm run sync:stiftelser (cachar ~22 MB JSON lokalt)
# STIFTELSE_JSON_URL=https://stiftelser.lansstyrelsen.se/%C3%96ppendata/Json

# --- Vektorminne / Qdrant (valfritt) ---
# Lokal: docker compose -f docker-compose.qdrant.yml up -d
QDRANT_URL=http://localhost:6333
# eller Qdrant Cloud:
# QDRANT_ENDPOINT=https://xxxx.cloud.qdrant.io
QDRANT_API_KEY=
# Embeddings via OpenRouter (samma nyckel som chat)
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
QDRANT_VECTOR_SIZE=2048

# Valfritt — browser-use.com cloud (ej använd av huvudflödet; se scripts/experiment_api.js)
# BROWSER_USE_API_KEY=

# --- Auth (ändra i produktion) ---
ADMIN_USERNAME=sitk_admin
ADMIN_PASSWORD=pelle

# --- Entitet PII (valfritt) ---
ENTITY_PER_ORGNR=
ENTITY_PER_PHONE=
ENTITY_SITK_ORGNR=
ENTITY_SITK_PHONE=

# --- Server ---
PORT=3001
NODE_ENV=development

# Frontend (Vercel: sätt inte om API och UI deployas tillsammans)
# VITE_API_URL=

# Valfritt — GitHub API (scripts, ej committa riktig token)
# GITHUB_TOKEN=ghp_...